import xarray as xr
import os
import numpy as np
import pandas as pd
import netCDF4 as nc

class TrajectoryWriter:
    def __init__(self, output_dir):
        self.output_dir = output_dir
        if not os.path.exists(output_dir): 
            os.makedirs(output_dir)

    def create_file(self, name, start_sim, end_sim, dt, total_particles, init_coords, cfg_ref, station_name):
        """
        Creates netCDF output with status variable, global attributes, and running mode.
        """
        file_path = os.path.join(self.output_dir, f"{name}.nc")
        
        # Handle time range for both forward and backward runs
        if dt > 0:
            times = pd.date_range(start=start_sim, end=end_sim, freq=f"{dt}s")
        else:
            # Reverses the range for backward modeling
            times = pd.date_range(start=end_sim, end=start_sim, freq=f"{abs(dt)}s")[::-1]
            
        lon0, lat0, z0 = init_coords

        # Initialize Dataset with status variable (Live=1, Dead=0)[cite: 17]
        ds = xr.Dataset(
            {
                "lon": (["time", "particle"], np.full((len(times), total_particles), lon0, dtype="f4")),
                "lat": (["time", "particle"], np.full((len(times), total_particles), lat0, dtype="f4")),
                "z": (["time", "particle"], np.full((len(times), total_particles), z0, dtype="f4")),
                "status": (["time", "particle"], np.zeros((len(times), total_particles), dtype="i1"))
            },
            coords={"time": times, "particle": np.arange(total_particles)}
        )

        # Add Global Attributes[cite: 17]
        ds.attrs["Author"] = "Dr Dwiyoga Nugroho, RCO-BRIn 2026"
        ds.attrs["branding"] = cfg_ref.config['Startup']['branding']
        ds.attrs["mode"] = cfg_ref.config['Simulation']['mode']
        ds.attrs["running_mode"] = "forward" if dt > 0 else "backward"
        ds.attrs["source_name"] = station_name
        ds.attrs["start_simulation"] = str(start_sim)
        ds.attrs["end_simulation"] = str(end_sim)

        # Extract source-specific release dates and depth_release from namelist[cite: 17]
        for s_key in [k for k in cfg_ref.config.sections() if k.startswith('Source')]:
            if cfg_ref.config[s_key]['name'] == station_name:
                ds.attrs["type"] = cfg_ref.config[s_key].get('type', 'N/A')
                ds.attrs["start_release_date"] = cfg_ref.config[s_key]['start_date_release']
                ds.attrs["end_release_date"] = cfg_ref.config[s_key]['end_date_release']
                ds.attrs["depth_release"] = cfg_ref.config[s_key].get('depth', '0.0')

        ds.to_netcdf(file_path, engine='netcdf4')
        ds.close()

    def write_step(self, loc_name, time, lons, lats, depths, status):
        """Writes current step data with a safety cap for particle count[cite: 17]."""
        file_path = os.path.join(self.output_dir, f"{loc_name}.nc")
        n_active = len(lons)
        if n_active == 0: return

        with nc.Dataset(file_path, 'r+') as root:
            time_var = root.variables['time']
            target_time = nc.date2num(time, units=time_var.units, calendar=time_var.calendar)
            
            # Find exact index for current simulation time[cite: 17]
            time_indices = np.where(np.isclose(time_var[:], target_time))[0]
            if len(time_indices) == 0: return
            time_idx = time_indices[0]

            # Determine max capacity of the file to prevent reshape/broadcast errors[cite: 17]
            max_p = root.variables['lon'].shape[1]
            write_count = min(n_active, max_p)

            # Write only up to the pre-allocated limit[cite: 17]
            root.variables['lon'][time_idx, 0:write_count] = lons[:write_count]
            root.variables['lat'][time_idx, 0:write_count] = lats[:write_count]
            root.variables['z'][time_idx, 0:write_count] = depths[:write_count]
            root.variables['status'][time_idx, 0:write_count] = status[:write_count]
