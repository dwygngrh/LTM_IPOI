import xarray as xr
import os
import numpy as np
import pandas as pd
import netCDF4 as nc

class TrajectoryWriter:
    def __init__(self, output_dir):
        self.output_dir = output_dir
        if not os.path.exists(output_dir): 
            os.makedirs(output_dir)

    def create_file(self, name, start_sim, end_sim, dt, total_particles, init_coords, cfg_ref):
        """
        Creates netCDF output with the status variable and global attributes.
        """
        file_path = os.path.join(self.output_dir, f"{name}.nc")
        times = pd.date_range(start=start_sim, end=end_sim, freq=f"{dt}s")
        lon0, lat0, z0 = init_coords

        # Initialize Dataset with status variable[cite: 5, 6]
        ds = xr.Dataset(
            {
                "lon": (["time", "particle"], np.full((len(times), total_particles), lon0, dtype="f4")),
                "lat": (["time", "particle"], np.full((len(times), total_particles), lat0, dtype="f4")),
                "z": (["time", "particle"], np.full((len(times), total_particles), z0, dtype="f4")),
                "status": (["time", "particle"], np.zeros((len(times), total_particles), dtype="i1"))
            },
            coords={"time": times, "particle": np.arange(total_particles)}
        )

        # Add Global Attributes from namelist and user request
        ds.attrs["Author"] = "Dr Dwiyoga Nugroho, RCO-BRIn 2026"
        ds.attrs["branding"] = cfg_ref.config['Startup']['branding']
        ds.attrs["mode"] = cfg_ref.config['Simulation']['mode']
        ds.attrs["type"] = cfg_ref.config['Microplastic' if ds.attrs["mode"] == 'microplastic' else 'MarineDebris'].get('shape', 'N/A')
        ds.attrs["source_name"] = name
        ds.attrs["start_simulation"] = str(start_sim)
        ds.attrs["end_simulation"] = str(end_sim)

        # Extract source-specific release dates
        for s_key in [k for k in cfg_ref.config.sections() if k.startswith('Source')]:
            if cfg_ref.config[s_key]['name'] == name:
                ds.attrs["start_release_date"] = cfg_ref.config[s_key]['start_date_release']
                ds.attrs["end_release_date"] = cfg_ref.config[s_key]['end_date_release']

        ds.to_netcdf(file_path, engine='netcdf4')
        ds.close()

    def write_step(self, loc_name, time, lons, lats, depths, status):
        """Writes current step data including the live/dead status[cite: 5, 6]."""
        file_path = os.path.join(self.output_dir, f"{loc_name}.nc")
        n_active = len(lons)
        if n_active == 0: return

        with nc.Dataset(file_path, 'r+') as root:
            time_var = root.variables['time']
            target_time = nc.date2num(time, units=time_var.units, calendar=time_var.calendar)
            
            # Find exact index for current simulation time[cite: 6]
            time_idx = np.where(time_var[:] == target_time)[0][0]

            root.variables['lon'][time_idx, 0:n_active] = lons
            root.variables['lat'][time_idx, 0:n_active] = lats
            root.variables['z'][time_idx, 0:n_active] = depths
            # Update the status variable[cite: 5]
            root.variables['status'][time_idx, 0:n_active] = status
